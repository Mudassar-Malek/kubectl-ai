# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Choose your LLM provider: "ollama" (free, local) or "anthropic" (paid API)
LLM_PROVIDER=ollama

# -----------------------------------------------------------------------------
# OLLAMA (Free, Local) - RECOMMENDED FOR GETTING STARTED
# -----------------------------------------------------------------------------
# Install: https://ollama.ai
# Start:   ollama serve
# Model:   ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
K8S_BOT_MODEL=llama3.2:3b

# Alternative models:
# K8S_BOT_MODEL=llama3.1:8b      # Larger, better quality (requires GPU or patience)
# K8S_BOT_MODEL=mistral:7b       # Good reasoning
# K8S_BOT_MODEL=qwen2.5:7b       # Multilingual

# -----------------------------------------------------------------------------
# ANTHROPIC Claude (Paid API) - Uncomment to use
# -----------------------------------------------------------------------------
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# K8S_BOT_MODEL=claude-sonnet-4-20250514

# =============================================================================
# K8s Bot Configuration
# =============================================================================
K8S_BOT_SAFE_MODE=true           # Require confirmation for destructive operations
K8S_BOT_DRY_RUN=false            # Enable dry-run mode by default
K8S_BOT_CONFIRM_COMMANDS=false   # Show command and ask approval before executing
K8S_BOT_TIMEOUT=30               # Command timeout in seconds
K8S_BOT_LOG_LEVEL=INFO           # Logging level: DEBUG, INFO, WARNING, ERROR

# Kubernetes Configuration
KUBECONFIG=~/.kube/config        # Path to kubeconfig file

# =============================================================================
# Optional: Slack Integration
# =============================================================================
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_APP_TOKEN=xapp-your-app-token
# SLACK_SIGNING_SECRET=your-signing-secret
